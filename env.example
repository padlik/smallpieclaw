# Copy this to .env and fill in your values

# Required Telegram Configuration
TM_TELEGRAM_TOKEN=your_bot_token_here

# ================================
# Provider Configuration
# ================================
# Supported providers: "openai" or "grok"
# Leave provider unset to auto-detect from URL

# Reasoning LLM Configuration
TM_LLM_PROVIDER=grok  # or "openai"
TM_LLM_BASE_URL=https://api.x.ai/v1  # Grok API
# TM_LLM_BASE_URL=https://api.openai.com/v1  # OpenAI API
TM_LLM_API_KEY=your_x_ai_api_key  # or OpenAI key
TM_LLM_MODEL=grok-beta

# Embeddings Configuration (can be different provider)
TM_EMBEDDINGS_PROVIDER=grok  # or "openai"
TM_EMBEDDINGS_BASE_URL=https://api.x.ai/v1
TM_EMBEDDINGS_API_KEY=your_x_ai_api_key
TM_EMBEDDINGS_MODEL=text-embedding-3-small

# ================================
# Security Configuration
# ================================
TM_ADMIN_ID=your_telegram_user_id
TM_PAIR_SECRET=your_pairing_secret

# ================================
# System Limits
# ================================
TM_MAX_STEPS=8
TM_TOOL_TIMEOUT=10
TM_MAX_OUTPUT_BYTES=20000

