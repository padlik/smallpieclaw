# Copy this to .env and fill in your values
# Never commit .env to version control

TELEGRAM_TOKEN=your_telegram_bot_token_here

# LLM provider: openai | claude | google | openrouter
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
# CLAUDE_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# OPENROUTER_API_KEY=sk-or-...

# Model overrides (optional)
# OPENAI_MODEL=gpt-4o-mini
# CLAUDE_MODEL=claude-3-5-haiku-20241022
# GOOGLE_MODEL=gemini-1.5-flash
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# Embedding provider for semantic tool search
EMBEDDING_PROVIDER=openai
# EMBEDDING_PROVIDER=none   # disables embeddings, uses TF-IDF

# Security
# Option 1: allow-list (comma-separated Telegram user IDs)
# ALLOWED_USER_IDS=123456789,987654321

# Option 2: PIN pairing (default if ALLOWED_USER_IDS is empty)
PAIRING_PIN=changeme123

# Agent tuning (optional)
# MAX_STEPS=8
# TOOL_TIMEOUT_SEC=10
# TOOL_OUTPUT_MAX=2000
