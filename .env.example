# Copy this to .env and fill in your values
# Never commit .env to version control

TELEGRAM_TOKEN=your_telegram_bot_token_here

# ── LLM provider ──────────────────────────────────────────────────────────────
# Options: openai | claude | google | openrouter | openai_compatible
LLM_PROVIDER=openai

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Optional: override the API base URL (applies even for LLM_PROVIDER=openai).
# Useful for Azure OpenAI, self-hosted proxies, or any drop-in replacement.
# OPENAI_BASE_URL=https://my-azure-resource.openai.azure.com/

# ── Claude ────────────────────────────────────────────────────────────────────
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-3-5-haiku-20241022

# ── Google Gemini ─────────────────────────────────────────────────────────────
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODEL=gemini-1.5-flash

# ── OpenRouter ────────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# ── Generic OpenAI-compatible endpoint ────────────────────────────────────────
# Set LLM_PROVIDER=openai_compatible and configure the three vars below.
# The server must implement the OpenAI Chat Completions API (/v1/chat/completions).
#
# Examples:
#   Ollama (local):      OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
#   LM Studio (local):   OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
#   vLLM (self-hosted):  OPENAI_COMPATIBLE_BASE_URL=http://my-server:8000/v1
#   Groq:                OPENAI_COMPATIBLE_BASE_URL=https://api.groq.com/openai/v1
#   Together AI:         OPENAI_COMPATIBLE_BASE_URL=https://api.together.xyz/v1
#   Mistral:             OPENAI_COMPATIBLE_BASE_URL=https://api.mistral.ai/v1
#
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPATIBLE_API_KEY=ollama        # many local servers accept any string
# OPENAI_COMPATIBLE_MODEL=llama3

# ── Embeddings ────────────────────────────────────────────────────────────────
# Options: openai | google | openai_compatible | none
# "openai_compatible" reuses OPENAI_COMPATIBLE_BASE_URL/KEY — set EMBEDDING_MODEL
#   to the embedding model name your server supports (e.g. "nomic-embed-text").
# "none" disables vector search and falls back to TF-IDF (zero API calls).
EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_MODEL=nomic-embed-text        # example for Ollama

# ── Security ──────────────────────────────────────────────────────────────────
# Option 1: allow-list (comma-separated Telegram user IDs)
# ALLOWED_USER_IDS=123456789,987654321

# Option 2: PIN pairing (default when ALLOWED_USER_IDS is empty)
PAIRING_PIN=changeme123

# ── Agent tuning (optional) ───────────────────────────────────────────────────
# MAX_STEPS=8
# TOOL_TIMEOUT_SEC=10
# TOOL_OUTPUT_MAX=2000
